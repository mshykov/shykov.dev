rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Posts: Anyone can read published posts. Only authenticated users can read unpublished or write.
    // NOTE: for `list` queries Firestore does not filter results through rules — it rejects the whole
    // query unless it is provably scoped to allowed docs. Any unauthenticated query against /posts
    // MUST therefore carry `where('published','==',true)` (see src/components/PostList.tsx), or it will
    // fail with permission-denied. Keep that filter on every anonymous list query.
    match /posts/{postId} {
      allow read: if resource.data.published == true || request.auth != null;
      // The site has no client-side write UI; posts are authored out-of-band via
      // the Firebase console / Admin SDK, which bypass these rules. So deny all
      // client writes rather than the previous `request.auth != null`, which would
      // let ANY signed-in account create/overwrite/delete ANY post the moment an
      // auth provider is enabled. If a client-side editor is ever added, replace
      // this with an owner-uid check, e.g. `request.auth.uid == 'YOUR_OWNER_UID'`.
      allow write: if false;
    }
    
    // Users: Users can only read and write their own profile data.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
